# AWS Configuration
# Get these from your AWS Console after setting up AppSync and Cognito

# AWS Region (e.g., us-east-1, eu-west-1)
VITE_AWS_REGION=us-east-1

# Cognito User Pool ID (from Cognito Console)
VITE_AWS_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito User Pool Client ID (from Cognito Console)
VITE_AWS_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AppSync GraphQL Endpoint URL (from AppSync Console)
VITE_AWS_APPSYNC_ENDPOINT=https://xxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql

# AppSync API Key (optional - only if using API_KEY auth mode)
VITE_AWS_APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxx
