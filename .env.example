# GameSphere Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# APPLICATION ENVIRONMENT
# ===========================================
# Options: mock | development | production
# - mock: Uses mock data and local storage auth (no AWS needed)
# - development: Uses real AWS services with debug logging
# - production: Uses real AWS services, no debug logging
VITE_APP_ENV=mock

# ===========================================
# AWS REGION
# ===========================================
VITE_AWS_REGION=us-east-1

# ===========================================
# COGNITO CONFIGURATION
# ===========================================
# Auth provider options: mock | amplify | cognito
# - mock: Uses mock auth service with local storage (no AWS)
# - amplify: Uses AWS Amplify Auth (simpler setup, less control)
# - cognito: Uses direct AWS Cognito SDK (more control, more setup)
VITE_AUTH_PROVIDER=cognito

# Get these from AWS Cognito Console
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===========================================
# APPSYNC CONFIGURATION  
# ===========================================
# Get these from AWS AppSync Console
VITE_APPSYNC_ENDPOINT=https://xxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
VITE_APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxx
