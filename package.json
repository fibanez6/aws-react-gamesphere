    "amp:sandbox": "npx ampx sandbox",
    "amp:sandbox:delete": "npx ampx sandbox delete",
    "seed": "node scripts/seed-dynamodb-data.js",
    "seed:delete": "node scripts/seed-dynamodb-data.js --delete",
    "seed:users": "node scripts/seed-cognito-user.js",
    "seed:users:delete": "node scripts/seed-cognito-user.js --delete"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "~6.13.2",
    "@tailwindcss/vite": "^4.2.1",
    "aws-amplify": "~6.15.10",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.0"
  },
  "engines": {
    "node": ">= 20.20.0",
    "npm": ">= 10.8.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "~1.19.0",
    "@aws-amplify/backend-cli": "~1.8.1",
    "@aws-sdk/client-cognito-identity-provider": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.1000.0",
    "@eslint/compat": "~2.0.1",
    "@eslint/eslintrc": "~3.3.3",
    "@eslint/js": "~9.39.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "~18.3.27",
    "@types/react-dom": "~18.3.7",
    "@typescript-eslint/eslint-plugin": "~8.53.0",
    "@typescript-eslint/parser": "~8.53.0",
    "@vitejs/plugin-react": "~5.1.2",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.3.1",
    "esbuild": "~0.27.2",
    "eslint": "~9.39.2",
    "eslint-plugin-react-hooks": "~7.0.1",
    "eslint-plugin-react-refresh": "~0.4.26",
    "globals": "~17.0.0",
    "path": "^0.12.7",
